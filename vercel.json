{
  "buildCommand": "cd phoneguessr && npm install && npm run build && cp dist/html/index/index.html dist/index.html && cp -r dist/public/* dist/",
  "devCommand": "cd phoneguessr && npm run dev",
  "outputDirectory": "phoneguessr/dist",
  "rewrites": [
    { "source": "/api/puzzle/:action", "destination": "/api/puzzle?action=:action" },
    { "source": "/api/leaderboard/:period", "destination": "/api/leaderboard?period=:period" },
    { "source": "/api/auth/login", "destination": "/api/auth?action=login" },
    { "source": "/api/auth/logout", "destination": "/api/auth?action=logout" },
    { "source": "/api/auth/me", "destination": "/api/auth?action=me" },
    { "source": "/api/auth/callback", "destination": "/api/auth?action=callback" },
    { "source": "/api/auth/telegram", "destination": "/api/auth?action=telegram" },
    { "source": "/api/profile/:path*", "destination": "/api/profile" },
    { "source": "/api/admin/phones", "destination": "/api/admin?resource=phones" },
    { "source": "/api/admin/reset", "destination": "/api/admin?resource=reset" },
    { "source": "/api/admin/reset/:action", "destination": "/api/admin?resource=reset&action=:action" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "phoneguessr/{src,config/public/phones}/**"
    }
  }
}
